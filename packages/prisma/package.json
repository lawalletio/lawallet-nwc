{
  "name": "@lawallet-nwc/prisma",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "dev": "prisma generate --watch",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf src/generated"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "prisma": "^6.19.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
