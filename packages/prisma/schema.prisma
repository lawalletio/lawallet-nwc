generator client {
  provider      = "prisma-client-js"
  output        = "./src/generated"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
  USER
}

enum InvoicePurpose {
  REGISTRATION
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
}

model User {
  id               String            @id
  pubkey           String            @unique
  createdAt        DateTime          @default(now())
  nwc              String?
  cardDesigns      CardDesign[]
  ntag424s         Ntag424[]
  lightningAddress LightningAddress?
  cards            Card[]
  invoices         Invoice[]
  albySubAccount   AlbySubAccount?
  albyEnabled      Boolean           @default(false)
  role             UserRole          @default(USER)
  nwcConnections   NwcConnection[]

  @@index([role])
}

model CardDesign {
  id          String   @id @default(uuid())
  imageUrl    String
  description String
  createdAt   DateTime @default(now())
  cards       Card[]
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Ntag424 {
  cid       String   @id
  k0        String
  k1        String
  k2        String
  k3        String
  k4        String
  ctr       Int
  createdAt DateTime @default(now())
  card      Card?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LightningAddress {
  username  String   @id
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Card {
  id         String    @id @default(uuid())
  designId   String
  ntag424Cid String?   @unique
  createdAt  DateTime  @default(now())
  title      String?
  lastUsedAt DateTime?
  userId     String?
  username   String?
  otc        String?

  design  CardDesign @relation(fields: [designId], references: [id])
  ntag424 Ntag424?   @relation(fields: [ntag424Cid], references: [cid])
  user    User?      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AlbySubAccount {
  appId       Int      @id
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  username    String?
  nwcUri      String
  nostrPubkey String?
  createdAt   DateTime @default(now())
}

model Settings {
  name      String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Invoice {
  id          String         @id @default(uuid())
  bolt11      String
  paymentHash String         @unique
  amountSats  Int
  description String
  purpose     InvoicePurpose
  metadata    Json?
  status      InvoiceStatus  @default(PENDING)
  preimage    String?
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  paidAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([purpose, status])
}

// ============================================================================
// nostr-trigger service models
// ============================================================================

model NwcConnection {
  id           String            @id @default(cuid())
  label        String
  walletPubkey String
  clientPubkey String
  clientSecret String
  relays       String[]
  enabled      Boolean           @default(true)
  ownerUserId  String?
  owner        User?             @relation(fields: [ownerUserId], references: [id])
  webhooks     WebhookEndpoint[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([walletPubkey])
  @@index([ownerUserId])
  @@index([enabled])
}

model WebhookEndpoint {
  id              String        @id @default(cuid())
  nwcConnectionId String
  nwcConnection   NwcConnection @relation(fields: [nwcConnectionId], references: [id], onDelete: Cascade)
  url             String
  secret          String
  eventKinds      Int[]         @default([23196, 23197])
  enabled         Boolean       @default(true)
  createdAt       DateTime      @default(now())

  @@index([nwcConnectionId])
}

model NostrTriggerAdmin {
  id        String   @id @default(cuid())
  pubkey    String   @unique
  label     String?
  addedBy   String?
  createdAt DateTime @default(now())
}

model AuditEvent {
  id      String   @id @default(cuid())
  ts      DateTime @default(now())
  source  String
  actor   String?
  action  String
  target  String?
  payload Json?

  @@index([ts])
  @@index([actor])
  @@index([action])
}

model ZapReceiptLedger {
  id          String   @id @default(cuid())
  eventId     String   @unique
  bolt11      String
  recipient   String
  zapRequest  Json
  publishedAt DateTime @default(now())
  relays      String[]

  @@index([recipient])
}
