{
  "name": "lawallet-nwc-monorepo",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@lawallet-nwc/web",
    "dev:docs": "turbo run dev --filter=@lawallet-nwc/docs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "picomatch": "4.0.4",
      "yaml": "2.8.3",
      "effect": "3.21.0",
      "defu": "6.1.6",
      "bn.js": "4.12.3"
    }
  }
}
