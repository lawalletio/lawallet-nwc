{
  "name": "lawallet-nwc-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:setup": "node scripts/dev-worktree.mjs setup",
    "start:dev-server": "node scripts/dev-worktree.mjs start",
    "dev:bootstrap": "node scripts/dev-worktree.mjs bootstrap",
    "dev:db:reset": "node scripts/dev-worktree.mjs reset-db",
    "dev:env": "node scripts/dev-worktree.mjs env",
    "dev:web": "turbo run dev --filter=@lawallet-nwc/web",
    "dev:docs": "turbo run dev --filter=@lawallet-nwc/docs",
    "dev:openapi": "turbo run dev --filter=@lawallet-nwc/openapi",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "e2e": "turbo run e2e --filter=@lawallet-nwc/web",
    "e2e:domain": "turbo run e2e:domain --filter=@lawallet-nwc/web",
    "bench": "turbo run bench --filter=@lawallet-nwc/web",
    "format": "prettier --write .",
    "clean": "turbo run clean",
    "docs:check": "node scripts/docs-sync.mjs --check",
    "docs:sync": "node scripts/docs-sync.mjs --write",
    "studio": "pnpm --filter @lawallet-nwc/web exec prisma studio",
    "plugin:new": "node scripts/plugin-new.mjs"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.9.17"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.18.1",
      "picomatch": "4.0.4",
      "yaml": "2.8.3",
      "effect": "3.21.0",
      "defu": "6.1.6",
      "bn.js": "4.12.3",
      "minimatch@<4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "brace-expansion@<2": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "ajv@<7": "6.14.0",
      "postcss": "8.5.15",
      "esbuild": "0.28.1",
      "vite": "6.4.3",
      "ws": "8.21.0"
    }
  }
}
