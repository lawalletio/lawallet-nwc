{
  "compilerOptions": {
    "strict": true,
    "target": "ES6",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true
  },
  "exclude": ["node_modules"]
}
