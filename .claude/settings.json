{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-bootstrap.sh"
          }
        ]
      }
    ]
  }
}
