    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/pg": "^8.15.5",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
