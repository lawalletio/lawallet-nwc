generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
  USER
}

enum InvoicePurpose {
  REGISTRATION
  WALLET_ADDRESS
  LUD16_PAYMENT
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
}

enum LightningAddressMode {
  IDLE // address exists but does nothing (disabled)
  ALIAS // forwards to another LN address via `redirect`
  CUSTOM_NWC // uses the RemoteWallet referenced by remoteWalletId
  DEFAULT_NWC // uses the user's default RemoteWallet
}

enum RemoteWalletType {
  NWC
  LND
  CLN
  BTCPAY
}

enum RemoteWalletStatus {
  ACTIVE
  DISABLED
  REVOKED
}

/// A card's kind, declared at creation. SIMPLE cards only support
/// ownership-transfer activation; MASTER cards (reserved for the deferred
/// account-share feature) will additionally support FOREVER share grants.
enum CardKind {
  SIMPLE
  MASTER
}

/// The kind of an activation QR. ONE_TIME burns on first claim and transfers
/// card ownership. FOREVER is reserved for MASTER account-sharing and is not
/// mintable yet — the activation-token route rejects it.
enum ActivationQrKind {
  ONE_TIME
  FOREVER
}

/// Lifecycle of a CardActivationToken. ONE_TIME tokens reach CLAIMED on a
/// successful claim; superseded/rescued tokens become REVOKED.
enum ActivationTokenStatus {
  PENDING
  CLAIMED
  REVOKED
  EXPIRED
}

enum ActivityCategory {
  USER
  ADDRESS
  NWC
  INVOICE
  CARD
  SERVER
}

enum ActivityLevel {
  INFO
  WARN
  ERROR
}

model User {
  id                 String             @id
  pubkey             String             @unique
  createdAt          DateTime           @default(now())
  cardDesigns        CardDesign[]
  ntag424s           Ntag424[]
  lightningAddresses LightningAddress[]
  remoteWallets      RemoteWallet[]
  cards              Card[]
  invoices           Invoice[]
  albySubAccount     AlbySubAccount?
  albyEnabled        Boolean            @default(false)
  role               UserRole           @default(USER)
  activityLogs       ActivityLog[]

  @@index([role])
}

model CardDesign {
  id          String    @id @default(uuid())
  imageUrl    String
  description String
  createdAt   DateTime  @default(now())
  /// Non-null timestamp means the design has been archived and should be
  /// hidden from the default "Active" tab. Using a timestamp instead of a
  /// boolean so we can order archived designs by when they were archived.
  archivedAt  DateTime?
  cards       Card[]
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([archivedAt])
}

model Ntag424 {
  cid       String   @id
  k0        String
  k1        String
  k2        String
  k3        String
  k4        String
  ctr       Int
  createdAt DateTime @default(now())
  card      Card?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LightningAddress {
  username        String               @id
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode            LightningAddressMode @default(DEFAULT_NWC)
  redirect        String?
  remoteWalletId  String?
  remoteWallet    RemoteWallet?        @relation(fields: [remoteWalletId], references: [id], onDelete: SetNull)
  isPrimary       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
  @@index([remoteWalletId])
}

/// Generic remote wallet attached by a user. `type` discriminates the driver;
/// `config` holds the driver-specific payload (e.g. NWC URI + mode). Encryption
/// of `config` at rest is enforced at the application layer by the driver
/// registry — never persist `config` here without going through it.
model RemoteWallet {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      RemoteWalletType
  config    Json
  status    RemoteWalletStatus @default(ACTIVE)
  isDefault Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  lightningAddresses LightningAddress[]
  cards              Card[]

  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model Card {
  id             String    @id @default(uuid())
  designId       String
  ntag424Cid     String?   @unique
  createdAt      DateTime  @default(now())
  title          String?
  lastUsedAt     DateTime?
  // `userId` is the card's current *holder* (owner). A ONE_TIME activation
  // claim transfers this to the new claimer. Pay-time wallet resolution and
  // `users/[userId]/cards` both key off this field.
  userId         String?
  username       String?
  otc            String?
  remoteWalletId String?
  kind           CardKind  @default(SIMPLE)

  design           CardDesign            @relation(fields: [designId], references: [id])
  ntag424          Ntag424?              @relation(fields: [ntag424Cid], references: [cid])
  user             User?                 @relation(fields: [userId], references: [id])
  remoteWallet     RemoteWallet?         @relation(fields: [remoteWalletId], references: [id], onDelete: SetNull)
  activationTokens CardActivationToken[]

  @@index([userId])
  @@index([remoteWalletId])
}

/// An activation token backing a scannable QR for a card. At most one ACTIVE
/// (PENDING) token may exist per (cardId, qrKind) — enforced by a partial
/// unique index added in the migration (Prisma can't express partial indexes).
/// Minting a new token of the same kind first REVOKEs the prior one in a
/// transaction so the constraint holds.
model CardActivationToken {
  id              String                @id @default(cuid())
  cardId          String
  card            Card                  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  qrKind          ActivationQrKind      @default(ONE_TIME)
  status          ActivationTokenStatus @default(PENDING)
  /// The activation URL the wallet scans (e.g. `https://host/activate/<id>`).
  qrPayload       String
  /// DB id of the holder/operator who minted the token (audit only).
  issuedByUserId  String?
  expiresAt       DateTime?
  claimedAt       DateTime?
  /// DB id of the claimer (ONE_TIME only — single audit row).
  claimedByUserId String?
  createdAt       DateTime              @default(now())

  @@index([cardId])
  @@index([status])
}

model AlbySubAccount {
  appId       Int      @id
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  username    String? // alby sub account username@getalby.com
  nwcUri      String
  nostrPubkey String? // nostr pubkey for nip57
  createdAt   DateTime @default(now())
}

model Settings {
  name      String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Invoice {
  id          String         @id @default(uuid())
  bolt11      String
  paymentHash String         @unique
  amountSats  Int
  description String
  purpose     InvoicePurpose
  metadata    Json?
  status      InvoiceStatus  @default(PENDING)
  preimage    String?
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  paidAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([purpose, status])
}

model ActivityLog {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  category  ActivityCategory
  level     ActivityLevel    @default(INFO)
  event     String
  message   String
  reqId     String?
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadata  Json?

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([level, createdAt])
  @@index([userId, createdAt])
  @@index([reqId])
}

// Generic JSON-first storage for in-codebase plugins (apps/web/plugins/).
// Plugins persist ALL state here, validated by their own Zod schemas —
// never as new models/columns/enums, which are the merge-conflict seam for
// forks. See docs/PLUGINS.md.
model PluginRecord {
  id        String   @id @default(cuid())
  pluginId  String
  kind      String
  key       String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pluginId, kind, key])
  @@index([pluginId, kind])
}
