generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
  USER
}

enum InvoicePurpose {
  REGISTRATION
  WALLET_ADDRESS
  LUD16_PAYMENT
}

enum InvoiceStatus {
  PENDING
  PAID
  EXPIRED
}

enum LightningAddressMode {
  IDLE          // address exists but does nothing (disabled)
  ALIAS         // forwards to another LN address via `redirect`
  CUSTOM_NWC    // uses the NWCConnection referenced by nwcConnectionId
  DEFAULT_NWC   // uses the user's primary NWCConnection
}

enum NwcMode {
  RECEIVE
  SEND_RECEIVE
}

enum ActivityCategory {
  USER
  ADDRESS
  NWC
  INVOICE
  CARD
  SERVER
}

enum ActivityLevel {
  INFO
  WARN
  ERROR
}

model User {
  id                 String             @id
  pubkey             String             @unique
  createdAt          DateTime           @default(now())
  nwc                String?
  nwcUpdatedAt       DateTime?
  cardDesigns        CardDesign[]
  ntag424s           Ntag424[]
  lightningAddresses LightningAddress[]
  nwcConnections     NWCConnection[]
  cards              Card[]
  invoices           Invoice[]
  albySubAccount     AlbySubAccount?
  albyEnabled        Boolean            @default(false)
  role               UserRole           @default(USER)
  activityLogs       ActivityLog[]

  @@index([role])
}

model CardDesign {
  id          String    @id @default(uuid())
  imageUrl    String
  description String
  createdAt   DateTime  @default(now())
  /// Non-null timestamp means the design has been archived and should be
  /// hidden from the default "Active" tab. Using a timestamp instead of a
  /// boolean so we can order archived designs by when they were archived.
  archivedAt  DateTime?
  cards       Card[]
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([archivedAt])
}

model Ntag424 {
  cid       String   @id
  k0        String
  k1        String
  k2        String
  k3        String
  k4        String
  ctr       Int
  createdAt DateTime @default(now())
  card      Card?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LightningAddress {
  username        String               @id
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode            LightningAddressMode @default(DEFAULT_NWC)
  redirect        String?
  nwcConnectionId String?
  nwcConnection   NWCConnection?       @relation(fields: [nwcConnectionId], references: [id], onDelete: SetNull)
  isPrimary       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
  @@index([nwcConnectionId])
}

model NWCConnection {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionString   String
  mode               NwcMode            @default(RECEIVE)
  isPrimary          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lightningAddresses LightningAddress[]

  @@index([userId])
}

model Card {
  id         String    @id @default(uuid())
  designId   String
  ntag424Cid String?   @unique
  createdAt  DateTime  @default(now())
  title      String?
  lastUsedAt DateTime?
  userId     String?
  username   String?
  otc        String?

  design  CardDesign @relation(fields: [designId], references: [id])
  ntag424 Ntag424?   @relation(fields: [ntag424Cid], references: [cid])
  user    User?      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AlbySubAccount {
  appId       Int      @id
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  username    String? // alby sub account username@getalby.com
  nwcUri      String
  nostrPubkey String? // nostr pubkey for nip57
  createdAt   DateTime @default(now())
}

model Settings {
  name String @id
  value String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Invoice {
  id          String         @id @default(uuid())
  bolt11      String
  paymentHash String         @unique
  amountSats  Int
  description String
  purpose     InvoicePurpose
  metadata    Json?
  status      InvoiceStatus  @default(PENDING)
  preimage    String?
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  paidAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId])
  @@index([status])
  @@index([purpose, status])
}

model ActivityLog {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  category  ActivityCategory
  level     ActivityLevel    @default(INFO)
  event     String
  message   String
  reqId     String?
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadata  Json?

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([level, createdAt])
  @@index([userId, createdAt])
  @@index([reqId])
}