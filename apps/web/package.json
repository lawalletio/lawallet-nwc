{
  "name": "@lawallet-nwc/web",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "node scripts/check-db-online.mjs && next dev",
    "db:check": "node scripts/check-db-online.mjs",
    "db:generate": "prisma generate",
    "format": "prettier --write .",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix",
    "start": "prisma migrate deploy && next start",
    "service": "node ../cli/src/index.js service",
    "reset": "prisma migrate reset --force --skip-seed",
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "node e2e/provision-db.mjs && playwright test",
    "e2e:domain": "node e2e/provision-db.mjs && E2E_DOMAIN_LIVE=1 playwright test e2e/domain-routing.spec.ts",
    "e2e:ui": "node e2e/provision-db.mjs && playwright test --ui",
    "e2e:headed": "node e2e/provision-db.mjs && playwright test --headed",
    "e2e:update": "node e2e/provision-db.mjs && playwright test --update-snapshots",
    "bench": "vitest bench --run --config vitest.bench.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@getalby/sdk": "^7.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@lawallet-nwc/openapi": "workspace:*",
    "@lawallet-nwc/shared": "workspace:*",
    "@nostrify/nostrify": "npm:@jsr/nostrify__nostrify@^0.46.5",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
