# LaWallet NWC Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Required Variables
# ============================================

# PostgreSQL connection URL (Prisma format)
# Format: postgresql://user:password@host:port/dbname
# The default below matches the bundled docker-compose.yml — run
# `docker compose up -d postgres` to start a local instance with these
# credentials. Production should use a strong password.
DATABASE_URL="postgresql://lawallet:lawallet_password@localhost:5432/lawallet"

# ============================================
# Optional Variables
# ============================================

# Node environment (development, test, production)
# Defaults to development if not set
NODE_ENV="development"

# Server port (optional, Next.js has its own default)
# PORT=3000

# ============================================
# JWT Authentication
# ============================================

# JWT secret key for token signing and verification
# Must be at least 32 characters long
# Generate a strong random secret for production
# JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# ============================================
# Nostr Key Vault (passkey accounts)
# ============================================

# Master secret encrypting server-custodied Nostr keys for passkey-created
# accounts (AES-256-GCM, per-record key via HKDF). Must be at least 32
# characters. Generate with: openssl rand -base64 48
#
# WARNING: back this value up. Losing it makes every custodied Nostr key
# unrecoverable — passkey users who never exported their key lose their
# Nostr identity.
# KEY_VAULT_SECRET="your-key-vault-master-secret-at-least-32-characters"

# During rotation, list old secrets (comma-separated) so existing envelopes
# still decrypt while being re-encrypted under the new secret.
# KEY_VAULT_SECRET_PREVIOUS=""

# ============================================
# Alby Integration
# ============================================

# Alby Hub API configuration for automatic subaccount generation
# All three variables are required if you want to enable Alby integration
# ALBY_API_URL="http://umbrel.local:5900/api"
# ALBY_BEARER_TOKEN="your-alby-bearer-token"
# AUTO_GENERATE_ALBY_SUBACCOUNTS="false"

# ============================================
# GitHub (for scripts)
# ============================================

# GitHub personal access token for issue management scripts
# GITHUB_TOKEN="your-github-token"
# GITHUB_PROJECT_NUMBER="your-project-number"

# ============================================
# Maintenance Mode
# ============================================

# Enable maintenance mode (returns 503 for all requests)
# MAINTENANCE_MODE="false"

# ============================================
# Public Landing Redirect
# ============================================

# Root path `/` redirects to this URL.
# Defaults to https://lawallet.io when not set.
# NEXT_PUBLIC_LAWALLET_LANDING_URL="https://lawallet.io"

# ============================================
# Logging
# ============================================

# Log level can be "fatal" | "error" | "warn" | "info" | "debug" | "trace" | "silent"
# LOG_LEVEL="error"
# Human-readable log output for development (JSON when false)
# LOG_PRETTY="false"

# Prisma queries slower than this log at warn level. 0 disables.
# SLOW_QUERY_THRESHOLD_MS="100"

# ============================================
# Rate Limiting
# ============================================

# Toggle rate limiting for public endpoints (default: enabled)
# RATE_LIMIT_ENABLED="true"
# Window length in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS="60000"
# Max requests per window, unauthenticated (default: 60)
# RATE_LIMIT_MAX_REQUESTS="60"
# Max requests per window, authenticated (default: 300)
# RATE_LIMIT_MAX_REQUESTS_AUTH="300"

# Distributed rate limiting via Upstash Redis (optional — falls back to
# in-memory when unset; needed when running more than one instance)
# UPSTASH_REDIS_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_TOKEN="your-upstash-token"

# ============================================
# Request Size Limits
# ============================================

# Maximum request body size in bytes (default: 1048576 = 1MB)
# REQUEST_MAX_BODY_SIZE="1048576"
# Maximum JSON payload size in bytes (default: 102400 = 100KB)
# REQUEST_MAX_JSON_SIZE="102400"
# Maximum single file upload size in bytes (default: 5242880 = 5MB)
# REQUEST_MAX_FILE_SIZE="5242880"
# Maximum number of files per upload request (default: 10)
# REQUEST_MAX_FILES="10"

# ============================================
# Nostr Profile Cache
# ============================================

# Optional filesystem directory for cached Nostr avatar/cover bytes.
# Defaults to /app/data/nostr-profiles in production and .cache/nostr-profiles in dev.
# NOSTR_PROFILE_CACHE_DIR="/app/data/nostr-profiles"

# ============================================
# NWC Listener (optional relay bridge)
# ============================================

# Base URL of the optional NWC listener service (apps/listener). In Docker
# Compose set this when enabling the `listener` profile; on Vercel/Netlify
# point it at your separately
# hosted listener (Railway/Render/Fly.io/VPS). Can also be managed at runtime
# in Admin → Settings → NWC Services (DB values override these).
# LISTENER_URL="http://listener:4100"
# Webhook HMAC secret (min 32 chars) — same value as LISTENER_AUTH_SECRET on
# the listener host. Also authenticates outgoing calls unless the dedicated
# request secret below is set.
# LISTENER_AUTH_SECRET=""
# Optional dedicated web→listener bearer secret. Set the same value as
# LISTENER_REQUEST_AUTH_SECRET on the listener host.
# LISTENER_REQUEST_AUTH_SECRET=""
# Timeout for NWC requests proxied through the listener (default: 10000)
# LISTENER_REQUEST_TIMEOUT_MS="10000"
