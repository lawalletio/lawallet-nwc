# LaWallet NWC Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Required Variables
# ============================================

# PostgreSQL connection URL (Prisma format)
# Format: postgresql://user:password@host:port/dbname
# The default below matches the bundled docker-compose.yml — run
# `docker compose up -d postgres` to start a local instance with these
# credentials. Production should use a strong password.
DATABASE_URL="postgresql://lawallet:lawallet_password@localhost:5432/lawallet"

# ============================================
# Optional Variables
# ============================================

# Node environment (development, test, production)
# Defaults to development if not set
NODE_ENV="development"

# Server port (optional, Next.js has its own default)
# PORT=3000

# ============================================
# JWT Authentication
# ============================================

# JWT secret key for token signing and verification
# Must be at least 32 characters long
# Generate a strong random secret for production
# JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# ============================================
# Alby Integration
# ============================================

# Alby Hub API configuration for automatic subaccount generation
# All three variables are required if you want to enable Alby integration
# ALBY_API_URL="http://umbrel.local:5900/api"
# ALBY_BEARER_TOKEN="your-alby-bearer-token"
# AUTO_GENERATE_ALBY_SUBACCOUNTS="false"

# ============================================
# GitHub (for scripts)
# ============================================

# GitHub personal access token for issue management scripts
# GITHUB_TOKEN="your-github-token"
# GITHUB_PROJECT_NUMBER="your-project-number"

# ============================================
# Maintenance Mode
# ============================================

# Enable maintenance mode (returns 503 for all requests)
# MAINTENANCE_MODE="false"

# ============================================
# Public Landing Redirect
# ============================================

# Root path `/` redirects to this URL.
# Defaults to https://lawallet.io when not set.
# NEXT_PUBLIC_LAWALLET_LANDING_URL="https://lawallet.io"

# ============================================
# Logging
# ============================================

# Log level can be "fatal" | "error" | "warn" | "info" | "debug" | "trace" | "silent"
# LOG_LEVEL="error"
# PRETTY_LOG="false"