{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "if [ \"$VERCEL_ENV\" = production ] && [ -n \"$DATABASE_URL\" ]; then n=0; until pnpm exec prisma migrate deploy; do n=$((n+1)); [ $n -ge 5 ] && exit 1; sleep 10; done; else echo skip-migrate; fi && next build",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
