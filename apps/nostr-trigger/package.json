{
  "name": "@lawallet-nwc/nostr-trigger",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --external=@prisma/client --external=.prisma/client",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: not configured yet'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lawallet-nwc/prisma": "workspace:*",
    "bullmq": "^5.34.0",
    "hono": "^4.9.10",
    "ioredis": "^5.4.1",
    "nostr-tools": "^2.10.0",
    "pg": "^8.13.1",
    "pino": "^10.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
