# ==============================================================================
# @lawallet-nwc/nostr-trigger — environment configuration
# ==============================================================================

# --- Core ---------------------------------------------------------------------
NODE_ENV=development
NT_PORT=3010
NT_LOG_LEVEL=info
NT_LOG_PRETTY=true

# AES-GCM 256 key (base64, 32 bytes) used to encrypt NwcConnection.clientSecret
# and WebhookEndpoint.secret at rest. Generate with:
#   openssl rand -base64 32
NT_MASTER_KEY=

# --- HTTP admin auth ----------------------------------------------------------
# Bearer token required on all /api/v1/* routes. Generate with:
#   openssl rand -hex 32
NT_ADMIN_SECRET=

# DANGER: when true, ALL authorization is disabled. Every HTTP request is
# accepted without a Bearer token, and every Nostr DM is treated as an admin
# command regardless of sender. For local dev only. NEVER set in production.
DANGEROUSLY_FREE=false

# --- Nostr identity + control plane ------------------------------------------
# Service nsec — used to receive encrypted DMs and reply to them.
NT_SERVICE_NSEC=
# Comma-separated relays the control plane listens on for encrypted DMs.
NT_CONTROL_RELAYS=wss://relay.damus.io,wss://relay.nostr.band

# LNURL/zapper nsec — signs NIP-57 kind-9735 zap receipts.
NT_LNURL_NSEC=
# Default relays for publishing zap receipts (merged with the zap request's relays tag).
NT_ZAP_DEFAULT_RELAYS=wss://relay.damus.io,wss://relay.nostr.band

# --- Storage ------------------------------------------------------------------
# Same Postgres as apps/web (shared via @lawallet-nwc/prisma)
DATABASE_URL=postgresql://lawallet:lawallet_password@localhost:5432/lawallet

# Redis for BullMQ + dedup set + per-subscription cursors
REDIS_URL=redis://localhost:6379/0

# --- Webhook delivery ---------------------------------------------------------
NT_WEBHOOK_MAX_ATTEMPTS=12
NT_WEBHOOK_INITIAL_DELAY_MS=10000
NT_WEBHOOK_MAX_DELAY_MS=3600000
NT_WEBHOOK_TIMEOUT_MS=10000

# --- Runtime ------------------------------------------------------------------
NT_DEDUP_TTL_SECONDS=259200
NT_CURSOR_OVERLAP_SECONDS=60
